# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram chat ID for the group (negative number for groups)
# Easiest way: add the bot to the group, send any message, then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and copy the chat.id field.
TELEGRAM_CHAT_ID=

# Optional: absolute path to the garmin-golf update/deploy script run by the
# /garmin command. Leave unset to use the default (the sibling project at
# ../garmin-golf/update.sh, resolved relative to this repo).
# GARMIN_UPDATE_SCRIPT=
